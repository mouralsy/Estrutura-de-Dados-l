#include <stdio.h>

void ImprimeVetor(int *v, int n){
    printf("\nVetor [%d]: ", n);
    for(int i=0; i<n; i++){
        printf("| %d ", v[i]);
    }
    printf("| ");
}

// ---------- MERGESORT ----------


void merge (int *v, int inicio, int meio, int fim){
    int i, j, k,*temp,tamanho p1, p2;
    int fim1 = fim2 = 0;
    tamanho = fim-inicio+1;
    p1 = inicio;
    p2 = meio + 1;
    temp = (int*) malloc(tamanho * (sizeof(int)));
    if (temp != NULL){
        for(i=0; i<tamanho; i ++){
            if(!fim1 && !fim2){ // se nenhum chegou ao fim
                if(v[p1]<v[p2]){
                    temp[i] = v[p1];
                    p1++;
                }else{
                    temp[i] = v[p2];
                    p2++;
                }
            }else{//se um dos dois vetores chegou ao fim
                if(!fim1){
                    temp[i] = v[p1++];
                }else{
                    temp[i] = v[p2++];
                }
            }
        }
        for(j=0, k=inicio; j<tamanho; j++, k++){
            v[k] = temp[j];
        }
    }
    free(temp);
}

void mergeSort (int *v, int inicio, int fim){
    int meio;
    if(inicio<fim){
        meio = floor((inico+fim)/2);
        mergeSort(v, inicio, meio);
        mergeSort(v, meio + 1, fim);
        merge(v, inicio, meio, fim);
}


